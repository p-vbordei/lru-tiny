{
  "name": "lru-tiny",
  "version": "0.1.0",
  "description": "LRU cache with optional TTL, O(1) ops, onEvict hook, pluggable clock. ~150 LoC, zero dependencies.",
  "keywords": ["lru", "cache", "ttl", "memoize"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": { "node": ">=18" },
  "author": { "name": "Vlad Bordei", "email": "bordeivlad@gmail.com", "url": "https://github.com/p-vbordei" },
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/p-vbordei/lru-tiny.git" },
  "bugs": { "url": "https://github.com/p-vbordei/lru-tiny/issues" },
  "homepage": "https://github.com/p-vbordei/lru-tiny#readme",
  "devDependencies": { "typescript": "^5.5.0", "vitest": "^2.0.0" }
}
